---
import Base from "../layouts/Base.astro";
import { BASE } from "../config";
---

<Base title="Página no encontrada - PixelSalud" noindex={true}>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center">
    <p class="text-6xl font-bold text-brand-600">404</p>
    <h1 class="mt-4 text-2xl font-bold">Esta página no existe</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-300">
      Puede que el enlace esté mal escrito o que hayamos movido el contenido.
    </p>
    <a
      href={`${BASE}/`}
      class="mt-8 inline-block rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700"
      >Volver al inicio</a
    >
  </section>
</Base>
